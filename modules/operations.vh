`define  shr_op  4'b0100
`define  shrc_op  4'b0101
`define  shl_op  4'b0110
`define  shlc_op  4'b0111

`define  add_op  4'b1000
`define  adc_op  4'b1001
`define  sd_op  4'b1010
`define  sdb_op  4'b1011
`define  sm_op  4'b1100
`define  smb_op  4'b1101

`define  nop3_op  4'b1110
`define  nop4_op  4'b1111

